{
  "name": "my-api-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "prestart": "docusaurus clear && node scripts/generate-askai-index.mjs && node scripts/generate-build-report.mjs",
    "prestart:dev": "docusaurus clear && node scripts/generate-askai-index.mjs && node scripts/generate-build-report.mjs",
    "prebuild": "docusaurus clear && node scripts/generate-askai-index.mjs && node scripts/generate-build-report.mjs",
    "predeploy": "docusaurus clear && node scripts/generate-askai-index.mjs && node scripts/generate-build-report.mjs",
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "start:dev": "cross-env ASKAI_INTERNAL_ANALYTICS=true docusaurus start",
    "build": "docusaurus build",
    "build:customer": "docusaurus build",
    "build:dev": "cross-env ASKAI_INTERNAL_ANALYTICS=true docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "npm run start",
    "serve:static": "npm run build && docusaurus serve",
    "pdf": "node scripts/generate-section-pdfs.mjs",
    "build-report": "node scripts/generate-build-report.mjs",
    "epic-metrics": "node scripts/generate-epic-release-metrics.mjs",
    "user-satisfaction-metrics": "node scripts/generate-user-satisfaction-metrics.mjs",
    "build-report:release": "node scripts/generate-epic-release-metrics.mjs && node scripts/generate-build-report.mjs",
    "wcag": "npm run build && node scripts/analyze-wcag-compliance.mjs",
    "test": "node --test scripts/generate-build-report.test.mjs",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids"
  },
  "dependencies": {
    "@docusaurus/core": "3.9.2",
    "@docusaurus/preset-classic": "3.9.2",
    "@mdx-js/react": "^3.0.0",
    "@monaco-editor/react": "^4.7.0",
    "@orama/plugin-docusaurus-v3": "^3.1.18",
    "clsx": "^2.0.0",
    "minisearch": "^7.2.0",
    "monaco-editor": "^0.55.1",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.9.2",
    "@docusaurus/types": "3.9.2",
    "cross-env": "^10.1.0",
    "playwright": "^1.53.1"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}
