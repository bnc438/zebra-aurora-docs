{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "dashboard-v2/pdf-validation-result.schema.json",
  "title": "PDF Validation Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "snapshotDate",
    "runId",
    "pdfId",
    "sectionKey",
    "outputPath",
    "renderAttempted",
    "renderSuccess",
    "renderDurationMs",
    "timeoutFlag",
    "fileExists",
    "pageCount",
    "brokenLinkCount",
    "imageFailureCount",
    "internalLinkCheckPassed",
    "externalLinkCheckPassed",
    "validationPassed"
  ],
  "properties": {
    "snapshotDate": { "type": "string", "format": "date" },
    "runId": { "type": "string", "minLength": 1 },
    "pdfId": { "type": "string", "minLength": 1 },
    "sectionKey": { "type": "string", "minLength": 1 },
    "outputPath": { "type": "string", "minLength": 1 },
    "renderAttempted": { "type": "boolean" },
    "renderSuccess": { "type": "boolean" },
    "renderDurationMs": { "type": "integer", "minimum": 0 },
    "timeoutFlag": { "type": "boolean" },
    "fileExists": { "type": "boolean" },
    "pageCount": { "type": "integer", "minimum": 0 },
    "brokenLinkCount": { "type": "integer", "minimum": 0 },
    "imageFailureCount": { "type": "integer", "minimum": 0 },
    "internalLinkCheckPassed": { "type": "boolean" },
    "externalLinkCheckPassed": { "type": "boolean" },
    "validationPassed": { "type": "boolean" },
    "failureReason": { "type": "string" }
  }
}
