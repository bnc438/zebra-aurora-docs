{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "dashboard-v2/release-fact.schema.json",
  "title": "Release Fact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "snapshotDate",
    "snapshotTimestamp",
    "versionRaw",
    "versionCanonical",
    "versionParseConfidence",
    "docCount",
    "docCompletenessPct",
    "prCount",
    "prLinkCoveragePct",
    "jiraEpicCount",
    "jiraOpenCount",
    "jiraInProgressCount",
    "jiraClosedCount",
    "jiraClosureRatePct",
    "releaseCoverageCompletenessPct",
    "buildStabilityScore",
    "pdfStabilityScore",
    "releaseReadinessIndex"
  ],
  "properties": {
    "snapshotDate": { "type": "string", "format": "date" },
    "snapshotTimestamp": { "type": "string", "format": "date-time" },
    "versionRaw": { "type": "string", "minLength": 1 },
    "versionCanonical": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "versionParseConfidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "docCount": { "type": "integer", "minimum": 0 },
    "docCompletenessPct": { "type": "number", "minimum": 0, "maximum": 100 },
    "prCount": { "type": "integer", "minimum": 0 },
    "prLinkCoveragePct": { "type": "number", "minimum": 0, "maximum": 100 },
    "jiraEpicCount": { "type": "integer", "minimum": 0 },
    "jiraOpenCount": { "type": "integer", "minimum": 0 },
    "jiraInProgressCount": { "type": "integer", "minimum": 0 },
    "jiraClosedCount": { "type": "integer", "minimum": 0 },
    "jiraClosureRatePct": { "type": "number", "minimum": 0, "maximum": 100 },
    "releaseCoverageCompletenessPct": { "type": "number", "minimum": 0, "maximum": 100 },
    "buildStabilityScore": { "type": "number", "minimum": 0, "maximum": 100 },
    "pdfStabilityScore": { "type": "number", "minimum": 0, "maximum": 100 },
    "releaseReadinessIndex": { "type": "number", "minimum": 0, "maximum": 100 }
  }
}
